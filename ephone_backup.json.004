  "ludoQuestions": [
    {
      "bankId": 2,
      "text": "如果我们一起去旅行，你最想去哪里，为什么？",
      "type": "both_answer",
      "id": 22
    },
    {
      "bankId": 2,
      "text": "你认为一段完美的关系中，最不可或缺的三个要素是什么？",
      "type": "both_answer",
      "id": 23
    },
    {
      "bankId": 2,
      "text": "分享一件最近因为我而让你感到心动或开心的小事。",
      "type": "both_answer",
      "id": 24
    },
    {
      "bankId": 2,
      "text": "回忆一下，我们第一次见面时，你对我的第一印象是什么？",
      "type": "both_answer",
      "id": 25
    },
    {
      "bankId": 2,
      "text": "如果我们可以一起学习一项新技能，你希望是什么？",
      "type": "both_answer",
      "id": 26
    },
    {
      "bankId": 2,
      "text": "描述一个你最希望和我一起度过的完美周末。",
      "type": "both_answer",
      "id": 27
    },
    {
      "bankId": 2,
      "text": "你觉得我们之间最有默契的一件事是什么？",
      "type": "both_answer",
      "id": 28
    },
    {
      "bankId": 2,
      "text": "如果用一种动物来形容我，你觉得是什么？为什么？",
      "type": "both_answer",
      "id": 29
    },
    {
      "bankId": 2,
      "text": "在未来的一年里，你最想和我一起完成的一件事是什么？",
      "type": "both_answer",
      "id": 30
    },
    {
      "bankId": 2,
      "text": "分享一部你最近很喜欢、并且想推荐给我一起看的电影或剧。",
      "type": "both_answer",
      "id": 31
    },
    {
      "bankId": 2,
      "text": "我们下次约会，你希望穿什么风格的衣服？",
      "type": "both_answer",
      "id": 32
    },
    {
      "bankId": 2,
      "text": "描述一下我最让你心动的一个瞬间。",
      "type": "single_answer",
      "id": 33
    },
    {
      "bankId": 2,
      "text": "诚实地说，我做的哪件事曾经让你偷偷生过气？",
      "type": "single_answer",
      "id": 34
    },
    {
      "bankId": 2,
      "text": "如果我有一种超能力，你希望是什么？",
      "type": "single_answer",
      "id": 35
    },
    {
      "bankId": 2,
      "text": "给我三个最贴切的标签。",
      "type": "single_answer",
      "id": 36
    },
    {
      "bankId": 2,
      "text": "在你心里，我的形象和你的理想型有多接近？",
      "type": "single_answer",
      "id": 37
    },
    {
      "bankId": 2,
      "text": "分享一个你觉得我可能不知道的，关于你的小秘密。",
      "type": "single_answer",
      "id": 38
    },
    {
      "bankId": 2,
      "text": "如果我们的故事是一首歌，你觉得歌名应该叫什么？",
      "type": "single_answer",
      "id": 39
    },
    {
      "bankId": 2,
      "text": "说一件你觉得我做得比你好/更擅长的事情。",
      "type": "single_answer",
      "id": 40
    },
    {
      "bankId": 2,
      "text": "如果可以回到我们认识的任意一天，你会选择哪一天，想做什么？",
      "type": "single_answer",
      "id": 41
    },
    {
      "bankId": 2,
      "text": "用三个词来形容你眼中的我们的关系。",
      "type": "single_answer",
      "id": 42
    }
